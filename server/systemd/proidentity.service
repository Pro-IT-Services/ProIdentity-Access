[Unit]
Description=ProIdentity Access Server
Wants=network-online.target
After=network-online.target mariadb.service mysql.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/proidentity
EnvironmentFile=-/etc/proidentity/proidentity.env
ExecStart=/opt/proidentity/bin/proidentity /etc/proidentity/config.yaml
Restart=on-failure
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
